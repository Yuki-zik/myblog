# Waline server basic site config
SITE_NAME=MyBlog
SITE_URL=https://blog.example.com
SERVER_URL=https://comments.example.com
JWT_TOKEN=replace-with-a-long-random-string

# Recommended safety config
SECURE_DOMAINS=https://blog.example.com,https://comments.example.com
COMMENT_AUDIT=false
AKISMET_KEY=false

# Supabase PostgreSQL connection
# Prefer the Session pooler values from Supabase when deploying on Vercel.
PG_HOST=aws-0-us-east-1.pooler.supabase.com
PG_PORT=6543
PG_DB=postgres
PG_USER=postgres.your-project-ref
PG_PASSWORD=replace-with-your-supabase-db-password
PG_PREFIX=wl_
PG_SSL=true
