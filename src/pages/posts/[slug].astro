---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import ArticleComments from "../../components/comments/ArticleComments";
import ParagraphComments from "../../components/comments/ParagraphComments";
import PostPager from "../../components/post/PostPager.astro";
import PostToc from "../../components/post/PostToc.astro";
import PostScholarRail from "../../components/post/PostScholarRail.astro";
import type { TufteRailFootnote } from "../../lib/markdown/rehypeTufteFootnotes";
import { TUFTE_MARKDOWN_FOOTNOTES_KEY } from "../../lib/markdown/rehypeTufteFootnotes";
import { resolvePostAuthor } from "../../lib/posts/author";
import { getPostSiblings } from "../../lib/posts/navigation";
import { buildPostToc } from "../../lib/posts/toc";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/article-comments.css";
import "../../styles/comments.css";

interface Props {
  post: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const resolvedAuthor = resolvePostAuthor(post);
const { Content, headings, remarkPluginFrontmatter } = await post.render();
const tocItems = buildPostToc(headings ?? []);
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const siblings = getPostSiblings(allPosts, post.slug);
const markdownFootnotes = Array.isArray(remarkPluginFrontmatter?.[TUFTE_MARKDOWN_FOOTNOTES_KEY])
  ? (remarkPluginFrontmatter[TUFTE_MARKDOWN_FOOTNOTES_KEY] as TufteRailFootnote[])
  : [];

// Reading time estimate: ~220 Chinese char/min, ~250 English words/min hybrid
const rawBody = post.body ?? "";
const chineseChars = (rawBody.match(/[\u4e00-\u9fff]/g) ?? []).length;
const latinWords = (rawBody.replace(/[\u4e00-\u9fff]/g, " ").match(/\b\w+\b/g) ?? []).length;
const readingMinutes = Math.max(1, Math.round(chineseChars / 220 + latinWords / 250));
const readingTimeLabel = readingMinutes <= 1 ? "约 1 分钟" : `约 ${readingMinutes} 分钟`;
---

<BaseLayout
  title={`${post.data.title} | 文章`}
  authorMeta={resolvedAuthor.name}
  mainClass="shell--article-reading"
>
  <!-- Reading progress bar -->
  <div class="reading-progress-bar" id="reading-progress-bar" role="progressbar" aria-label="阅读进度" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100}>
    <span class="reading-progress-bar__fill" data-reading-progress-fill aria-hidden="true"></span>
  </div>
  <script is:inline>
    (() => {
      const bar = document.getElementById('reading-progress-bar');
      const fill = bar?.querySelector('[data-reading-progress-fill]');
      if (!bar) return;
      if (bar.parentElement !== document.body) {
        document.body.appendChild(bar);
      }

      let ticking = false;
      const scheduleProgressUpdate = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateProgress);
          ticking = true;
        }
      };

      function updateProgress() {
        const article = document.querySelector('.post-reading-article');
        const articleBody = document.querySelector('[data-post-body]');
        const header = document.querySelector('.site-header');
        if (!(article instanceof HTMLElement) || !(articleBody instanceof HTMLElement)) return;

        const rect = article.getBoundingClientRect();
        const headerOffset = header instanceof HTMLElement ? Math.max(header.offsetHeight, 44) : 44;
        bar.dataset.floating = 'false';

        const articleStart = Math.max(window.scrollY + rect.top - headerOffset, 0);
        const articleEnd =
          articleStart +
          article.offsetHeight -
          Math.min(window.innerHeight * 0.6, articleBody.offsetHeight * 0.22);

        const total = Math.max(articleEnd - articleStart, 1);
        const scrolled = Math.min(Math.max(window.scrollY - articleStart, 0), total);
        const pct = Math.round((scrolled / total) * 100);

        bar.style.setProperty('--progress', pct + '%');
        if (fill instanceof HTMLElement) {
          fill.style.width = pct + '%';
        }
        bar.setAttribute('aria-valuenow', String(pct));
        ticking = false;
      }
      
      window.addEventListener('scroll', scheduleProgressUpdate, { passive: true });
      
      window.addEventListener('resize', () => {
        window.requestAnimationFrame(updateProgress);
      });
      
      updateProgress();
    })();
  </script>
  <script is:inline>
    // TOC smooth-scroll follow: scroll active item into view in left rail
    (() => {
      const FLAG = '__tocScrollBound';
      if (window[FLAG]) return;
      window[FLAG] = true;
      const tocRail = document.querySelector('.post-reading-toc-rail');
      if (!tocRail) return;
      const observer = new MutationObserver(() => {
        const active = tocRail.querySelector('.post-toc-link.is-active');
        if (!active) return;
        active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      });
      // Observe class changes on all toc links
      tocRail.querySelectorAll('.post-toc-link').forEach(el => {
        observer.observe(el, { attributes: true, attributeFilter: ['class'] });
      });
    })();
  </script>
  <script is:inline>
    (() => {
      const init = () => {
        const panel = document.querySelector('[data-reading-toc-panel]');
        if (!(panel instanceof HTMLDetailsElement)) return;

        const media = window.matchMedia('(max-width: 1180px)');
        const syncPanel = () => {
          panel.open = !media.matches;
        };

        syncPanel();
        media.addEventListener('change', syncPanel);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        init();
      }
    })();
  </script>

  <div class="post-reading-layout post-reading-layout--scholarly post-reading-layout--tri">
    {tocItems.length > 0 ? (
      <aside class="post-reading-toc-rail" aria-label="文章目录">
        <details class="post-reading-toc-panel" data-reading-toc-panel>
          <summary class="post-reading-toc-summary">目录</summary>
          <div class="post-reading-toc-body">
            <PostToc items={tocItems} variant="rail" />
          </div>
        </details>
      </aside>
    ) : null}

    <div class="post-reading-main">
      <article class="post-reading-article">
        {post.data.cover ? (
          <div class="post-cover post-cover--hero">
            <Image
              src={post.data.cover.src}
              alt={post.data.cover.alt}
              class="post-cover-img"
              loading="eager"
              decoding="async"
              widths={[640, 960, 1280]}
              sizes="(max-width: 900px) 100vw, 900px"
            />
            {post.data.cover.credit ? (
              <p class="post-cover-credit">{post.data.cover.credit}</p>
            ) : null}
          </div>
        ) : null}
        <header class="content-section post-header post-header--scholarly">
          <h1>{post.data.title}</h1>
          <p class="subtle post-header-meta">
            发布于 {new Date(post.data.date).toLocaleDateString("zh-CN")}
            {post.data.updated ? ` · 更新于 ${new Date(post.data.updated).toLocaleDateString("zh-CN")}` : ""}
            {" · 作者 "}
            {resolvedAuthor.name}
            {" · "}
            <span class="post-header-reading-time" aria-label={`预计阅读时间${readingTimeLabel}`}>{readingTimeLabel}阅读</span>
          </p>
          {post.data.summary ? <p class="post-header-dek">{post.data.summary}</p> : null}
          {post.data.topics.length > 0 ? (
            <p class="post-header-topics" aria-label="文章主题标签">
              <span class="post-header-topics-label">主题：</span>
              {post.data.topics.map((topicSlug) => (
                <span class="post-header-topic-item">
                  <a href={`/topics/${topicSlug}`}>#{topicSlug}</a>
                </span>
              ))}
            </p>
          ) : null}
        </header>

        <section class="post-body post-body--scholarly" data-post-body>
          <Content />
        </section>
      </article>

      <details class="post-article-comments-collapsible">
        <summary class="post-article-comments-summary">全文评论（展开）</summary>
        <div class="post-article-comments-panel">
          <ArticleComments client:load postSlug={post.slug} />
        </div>
      </details>

      <PostPager newerPost={siblings.newerPost} olderPost={siblings.olderPost} />
    </div>

    <aside class="post-reading-rail" aria-label="阅读侧栏">
      <PostScholarRail
        tocItems={tocItems}
        annotations={post.data.annotations ?? []}
        references={post.data.references ?? []}
        figures={post.data.figures ?? []}
        markdownFootnotes={markdownFootnotes}
        postSlug={post.slug}
        showToc={false}
      />
      <ParagraphComments client:load postSlug={post.slug} mode="rail" />
    </aside>
  </div>

</BaseLayout>
