---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticleComments from "../../components/comments/ArticleComments";
import PostToc from "../../components/post/PostToc.astro";
import PostScholarRail from "../../components/post/PostScholarRail.astro";
import type { TufteRailFootnote } from "../../lib/markdown/rehypeTufteFootnotes";
import { TUFTE_MARKDOWN_FOOTNOTES_KEY } from "../../lib/markdown/rehypeTufteFootnotes";
import { resolvePostAuthor } from "../../lib/posts/author";
import { buildPostToc } from "../../lib/posts/toc";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/article-comments.css";
import "../../styles/comments.css";

interface Props {
  post: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const resolvedAuthor = resolvePostAuthor(post);
const { Content, headings, remarkPluginFrontmatter } = await post.render();
const tocItems = buildPostToc(headings ?? []);
const markdownFootnotes = Array.isArray(remarkPluginFrontmatter?.[TUFTE_MARKDOWN_FOOTNOTES_KEY])
  ? (remarkPluginFrontmatter[TUFTE_MARKDOWN_FOOTNOTES_KEY] as TufteRailFootnote[])
  : [];

// Reading time estimate: ~220 Chinese char/min, ~250 English words/min hybrid
const rawBody = post.body ?? "";
const chineseChars = (rawBody.match(/[\u4e00-\u9fff]/g) ?? []).length;
const latinWords = (rawBody.replace(/[\u4e00-\u9fff]/g, " ").match(/\b\w+\b/g) ?? []).length;
const readingMinutes = Math.max(1, Math.round(chineseChars / 220 + latinWords / 250));
const readingTimeLabel = readingMinutes <= 1 ? "约 1 分钟" : `约 ${readingMinutes} 分钟`;
---

<BaseLayout
  title={`${post.data.title} | 文章`}
  authorMeta={resolvedAuthor.name}
  mainClass="shell--article-reading"
>
  <!-- Reading progress bar -->
  <div class="reading-progress-bar" id="reading-progress-bar" role="progressbar" aria-label="阅读进度" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100}></div>
  <script is:inline>
    (() => {
      const bar = document.getElementById('reading-progress-bar');
      if (!bar) return;
      let ticking = false;
      function updateProgress() {
        const article = document.querySelector('[data-post-body]');
        if (!article) return;
        const rect = article.getBoundingClientRect();
        const total = article.offsetHeight - window.innerHeight;
        const scrolled = Math.max(0, -rect.top);
        const pct = total > 0 ? Math.min(100, Math.round((scrolled / total) * 100)) : 0;
        bar.style.setProperty('--progress', pct + '%');
        bar.setAttribute('aria-valuenow', String(pct));
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(updateProgress); ticking = true; }
      }, { passive: true });
      updateProgress();
    })();
  </script>

  <div class="post-reading-layout post-reading-layout--scholarly post-reading-layout--tri">
    {tocItems.length > 0 ? (
      <aside class="post-reading-toc-rail" aria-label="文章目录">
        <details class="post-reading-toc-panel" open>
          <summary class="post-reading-toc-summary">目录</summary>
          <div class="post-reading-toc-body">
            <PostToc items={tocItems} variant="rail" />
          </div>
        </details>
      </aside>
    ) : null}

    <div class="post-reading-main">
      <article class="post-reading-article">
        <header class="content-section post-header post-header--scholarly">
          <h1>{post.data.title}</h1>
          <p class="subtle post-header-meta">
            发布于 {new Date(post.data.date).toLocaleDateString("zh-CN")}
            {post.data.updated ? ` · 更新于 ${new Date(post.data.updated).toLocaleDateString("zh-CN")}` : ""}
            {" · 作者 "}
            {resolvedAuthor.name}
            {" · "}
            <span class="post-header-reading-time" aria-label={`预计阅读时间${readingTimeLabel}`}>{readingTimeLabel}阅读</span>
          </p>
          {post.data.summary ? <p class="post-header-dek">{post.data.summary}</p> : null}
          {post.data.topics.length > 0 ? (
            <p class="post-header-topics" aria-label="文章主题标签">
              <span class="post-header-topics-label">主题：</span>
              {post.data.topics.map((topicSlug) => (
                <span class="post-header-topic-item">
                  <a href={`/topics/${topicSlug}`}>#{topicSlug}</a>
                </span>
              ))}
            </p>
          ) : null}
        </header>

        <section class="post-body post-body--scholarly" data-post-body>
          <Content />
        </section>
      </article>

      <details class="post-article-comments-collapsible">
        <summary class="post-article-comments-summary">全文评论（展开）</summary>
        <div class="post-article-comments-panel">
          <ArticleComments client:load postSlug={post.slug} />
        </div>
      </details>
    </div>

    <aside class="post-reading-rail" aria-label="阅读侧栏">
      <PostScholarRail
        tocItems={tocItems}
        annotations={post.data.annotations ?? []}
        references={post.data.references ?? []}
        figures={post.data.figures ?? []}
        markdownFootnotes={markdownFootnotes}
        postSlug={post.slug}
        showToc={false}
      />
    </aside>
  </div>
</BaseLayout>
