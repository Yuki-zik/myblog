---
import { getCollection } from "astro:content";
import PostCard from "../components/post/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const [topics, posts] = await Promise.all([
  getCollection("topics"),
  getCollection("posts", ({ data }) => !data.draft)
]);

const sortedTopics = topics.sort((a, b) => {
  const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
  const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
  if (orderA !== orderB) {
    return orderA - orderB;
  }
  return a.data.title.localeCompare(b.data.title, "zh-CN");
});

const latestPosts = [...posts]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const postCountByTopic = posts.reduce<Record<string, number>>((acc, post) => {
  post.data.topics.forEach((topicSlug) => {
    acc[topicSlug] = (acc[topicSlug] ?? 0) + 1;
  });
  return acc;
}, {});
---

<BaseLayout title="MyBlog | 主题化知识网络">
  <!-- Hero Banner -->
  <section class="home-hero content-section" data-ux-reveal="fade-up" aria-label="博客简介">
    <div class="home-hero-copy">
      <p class="home-hero-kicker">✦ 知识网络 · 段落短评</p>
      <h1 class="home-hero-title">主题化<br />知识网络</h1>
      <p class="home-hero-sub">
        从主题进入，深入文章，留下段落短评。<br />
        这里是阅读与思考交织的地方。
      </p>
      <div class="home-hero-actions">
        <a href="/topics" class="home-hero-btn home-hero-btn--primary">浏览主题</a>
        <a href="/archives" class="home-hero-btn home-hero-btn--ghost">进入归档</a>
      </div>
    </div>
    <div class="home-hero-stats" aria-label="博客统计">
      <div class="home-hero-stat">
        <span class="home-hero-stat-value">{posts.length}</span>
        <span class="home-hero-stat-label">篇文章</span>
      </div>
      <div class="home-hero-stat">
        <span class="home-hero-stat-value">{topics.length}</span>
        <span class="home-hero-stat-label">个主题</span>
      </div>
    </div>
  </section>

  <section class="grid topic-grid content-section" data-ux-stagger>
    {
      sortedTopics.map((topic) => (
        <article class="card" data-ux-reveal="fade-up">
          <h3>
            <a href={`/topics/${topic.slug}`}>{topic.data.title}</a>
          </h3>
          <p>{topic.data.summary}</p>
          <p class="subtle" style="margin-top: 0.6rem;">
            相关文章 {postCountByTopic[topic.slug] ?? 0} 篇
          </p>
        </article>
      ))
    }
  </section>

  <section class="content-section" data-latest-posts data-ux-reveal="fade-up">
    <h2>最新文章</h2>
    <p class="subtle">每篇文章都提供封面图，帮助你更快定位主题和上下文。</p>

    {
      latestPosts.length === 0 ? (
        <p class="subtle">暂时还没有可展示的文章。</p>
      ) : (
        <div class="grid post-card-grid" data-ux-stagger>
          {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
      )
    }
  </section>

  <section class="content-section home-archive-entry" data-home-archive-entry data-ux-reveal="fade-up">
    <h2>时间归档</h2>
    <p class="subtle">按年与月份浏览全部文章，快速定位你错过的内容。</p>
    <a class="archive-entry-button" href="/archives">进入归档时间轴</a>
  </section>

  <script is:inline>
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var hero = document.querySelector('.home-hero');
      if (!hero) return;
      var ticking = false;
      function onScroll() {
        var y = window.scrollY;
        var offset = Math.round(y * 0.12);
        hero.style.transform = 'translateY(' + offset + 'px)';
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
      }, { passive: true });
    })();
  </script>
</BaseLayout>
