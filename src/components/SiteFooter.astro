---
import { SITE_AUTHOR_PROFILE } from "../lib/site";

const year = new Date().getFullYear();
const github = SITE_AUTHOR_PROFILE.socials?.github;
---

<footer class="site-footer">
  <div class="shell site-footer-inner">
    <nav class="site-footer-nav" aria-label="页脚导航">
      <a href="/">首页</a>
      <a href="/topics">主题</a>
      <a href="/archives">归档</a>
      <a href="/author">作者</a>
      {github ? (
        <a
          href={`https://github.com/${github}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="在 GitHub 上查看"
          class="site-footer-github"
        >
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
      ) : null}
    </nav>
    <p class="site-footer-copy">
      © {year} {SITE_AUTHOR_PROFILE.name}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: none;
    position: relative;
    background: color-mix(in srgb, var(--surface-soft) 80%, transparent 20%);
    margin-top: 4rem;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--line) 20%,
      color-mix(in srgb, var(--accent) 30%, var(--line) 70%) 50%,
      var(--line) 80%,
      transparent 100%);
  }

  .site-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 1.25rem;
  }

  .site-footer-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem 1rem;
  }

  .site-footer-nav a {
    color: var(--subtle);
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-footer-nav a:hover {
    color: var(--text);
  }

  .site-footer-nav a:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 54%, var(--line-strong) 46%);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .site-footer-github {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .site-footer-copy {
    margin: 0;
    color: var(--subtle);
    font-size: 0.84rem;
  }

  @media (max-width: 600px) {
    .site-footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.55rem;
      padding-block: 1rem;
    }
  }
</style>
