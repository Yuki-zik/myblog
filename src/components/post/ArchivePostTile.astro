---
import type { CollectionEntry } from "astro:content";
import PostCover from "./PostCover.astro";

interface Props {
  post: CollectionEntry<"posts">;
  author: string;
  dateLabel: string;
}

const { post, author, dateLabel } = Astro.props;
---

<article class="archive-post-tile" data-archive-card data-ux-reveal="fade-up">
  <a
    href={`/posts/${post.slug}`}
    class="archive-post-link"
    aria-label={`Read post: ${post.data.title}, ${dateLabel} By ${author}`}
  >
    <div class="archive-post-media">
      <PostCover post={post} variant="archive-square" />
    </div>
    <div class="archive-post-content">
      <p class="archive-post-meta">
        <span data-archive-date>{dateLabel}</span>
        <span data-archive-author>By {author}</span>
      </p>
      <h3>{post.data.title}</h3>
      {post.data.summary ? <p class="archive-post-summary">{post.data.summary}</p> : null}
      <p class="archive-post-kicker">阅读文章</p>
    </div>
  </a>
</article>
