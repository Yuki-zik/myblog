---
import type { PostTocItem } from "../../lib/posts/toc";

interface Props {
  items: PostTocItem[];
  variant?: "standalone" | "rail" | "mobileOnly";
}

const { items, variant = "standalone" } = Astro.props;
---

<div class:list={["post-toc", variant === "rail" && "post-toc--rail"]} data-post-toc data-post-toc-variant={variant}>
  {
    variant === "rail" ? (
      <ol class="post-toc-list post-toc-list--rail">
        {
          items.map((item) => (
            <li class={`post-toc-item post-toc-item--depth-${item.depth}`}>
              <a
                href={`#${item.slug}`}
                class="post-toc-link"
                data-toc-link
                data-target-id={item.slug}
                data-toc-depth={item.depth}
              >
                <span class="post-toc-number">{item.numberLabel}</span>
                <span class="post-toc-text">{item.text}</span>
              </a>
            </li>
          ))
        }
      </ol>
    ) : (
      <>
        {variant !== "mobileOnly" && (
          <section class="post-toc-card post-toc-card--desktop" aria-label="文章目录">
            <h2 class="post-toc-title">目录</h2>
            <ol class="post-toc-list">
              {
                items.map((item) => (
                  <li class={`post-toc-item post-toc-item--depth-${item.depth}`}>
                    <a
                      href={`#${item.slug}`}
                      class="post-toc-link"
                      data-toc-link
                      data-target-id={item.slug}
                      data-toc-depth={item.depth}
                    >
                      <span class="post-toc-number">{item.numberLabel}</span>
                      <span class="post-toc-text">{item.text}</span>
                    </a>
                  </li>
                ))
              }
            </ol>
          </section>
        )}

        <details class="post-toc-mobile" data-post-toc-mobile>
          <summary class="post-toc-mobile-summary">目录</summary>
          <ol class="post-toc-list post-toc-list--mobile">

            {
              items.map((item) => (
                <li class={`post-toc-item post-toc-item--depth-${item.depth}`}>
                  <a
                    href={`#${item.slug}`}
                    class="post-toc-link"
                    data-toc-link
                    data-target-id={item.slug}
                    data-toc-depth={item.depth}
                  >
                    <span class="post-toc-number">{item.numberLabel}</span>
                    <span class="post-toc-text">{item.text}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </details>
      </>
    )
  }
</div>

<script>
  function initPostToc(root: Element): void {
    if (!(root instanceof HTMLElement) || root.dataset.ready === "true") {
      return;
    }
    root.dataset.ready = "true";

    const links = Array.from(root.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    const uniqueIds = Array.from(
      new Set(
        links.map((link) => link.dataset.targetId).filter((id): id is string => Boolean(id))
      )
    );

    const headings = uniqueIds
      .map((id) => document.getElementById(id))
      .filter((node): node is HTMLElement => node instanceof HTMLElement);

    if (headings.length === 0) {
      return;
    }

    const mobileDetails = root.querySelector<HTMLDetailsElement>("[data-post-toc-mobile]");
    const activeClass = "is-active";

    // Build a map: heading id → depth from data-toc-depth on its link
    const depthMap = new Map<string, number>();
    links.forEach((link) => {
      const id = link.dataset.targetId;
      const depth = Number(link.dataset.tocDepth ?? 2);
      if (id) depthMap.set(id, depth);
    });

    // Track which headings are currently visible in viewport
    const visibleSet = new Set<string>();

    function syncActive(): void {
      // Build set of active IDs: visible headings + the last heading above fold
      const headerOffset = 108;
      const activeIds = new Set<string>(visibleSet);

      // Always include the heading that's scrolled past (last above viewport top)
      let lastAbove: HTMLElement | null = null;
      for (const h of headings) {
        if (h.getBoundingClientRect().top - headerOffset <= 0) {
          lastAbove = h;
        } else {
          break;
        }
      }
      if (lastAbove) {
        activeIds.add(lastAbove.id);
      }

      links.forEach((link) => {
        const id = link.dataset.targetId ?? "";
        const active = activeIds.has(id);
        link.classList.toggle(activeClass, active);
        if (active) {
          link.setAttribute("aria-current", "true");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    }

    // Use IntersectionObserver to track which headings are in view
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = (entry.target as HTMLElement).id;
          if (entry.isIntersecting) {
            visibleSet.add(id);
          } else {
            visibleSet.delete(id);
          }
        });
        window.requestAnimationFrame(syncActive);
      },
      {
        // Track headings that are in the upper 80% of the viewport
        rootMargin: "-108px 0px -20% 0px",
        threshold: 0
      }
    );

    headings.forEach((heading) => {
      observer.observe(heading);
    });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        const targetId = link.dataset.targetId;
        if (targetId) {
          // Immediately show as active on click
          links.forEach((l) => l.classList.remove(activeClass));
          link.classList.add(activeClass);
        }

        if (
          mobileDetails instanceof HTMLDetailsElement &&
          window.matchMedia("(max-width: 900px)").matches
        ) {
          window.setTimeout(() => {
            mobileDetails.open = false;
          }, 40);
        }
      });
    });

    window.addEventListener("hashchange", () => {
      window.requestAnimationFrame(syncActive);
    });
    window.requestAnimationFrame(syncActive);
  }

  document.querySelectorAll("[data-post-toc]").forEach((root) => initPostToc(root));
</script>
