---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/animations.css";
import "../styles/layout.css";
import "../styles/footer.css";
import "../styles/search.css";
import "../styles/theme-toggle.css";
import "../styles/cards.css";
import "../styles/home.css";
import "../styles/toc.css";
import "../styles/author.css";
import "../styles/archives.css";
import "../styles/back-to-top.css";
import "../styles/article.css";
import "../styles/waline.css";
import SiteFooter from "../components/SiteFooter.astro";
import HeaderSearch from "../components/search/HeaderSearch.astro";
import { SITE_AUTHOR_PROFILE } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  authorMeta?: string;
  mainClass?: string;
}

const {
  title,
  description = "\u4e3b\u9898\u5316\u77e5\u8bc6\u7f51\u7edc\u4e0e\u6bb5\u843d\u77ed\u8bc4\u535a\u5ba2",
  authorMeta = SITE_AUTHOR_PROFILE.name,
  mainClass
} = Astro.props;

const pathname = Astro.url.pathname;
const currentSection = pathname === "/"
  ? "home"
  : pathname.startsWith("/topics") || pathname.startsWith("/posts") || pathname.startsWith("/concepts")
    ? "topics"
    : pathname.startsWith("/archives")
      ? "archives"
      : pathname.startsWith("/author")
        ? "author"
        : "";

const navItems = [
  { href: "/", label: "\u9996\u9875", section: "home" },
  { href: "/topics", label: "\u4e3b\u9898", section: "topics" },
  { href: "/archives", label: "\u5f52\u6863", section: "archives" },
  { href: "/author", label: "\u4f5c\u8005", section: "author" }
];

const themeInitScript = `(function () {
  var root = document.documentElement;
  var storageKey = "theme-preference";
  var valid = { system: true, light: true, dark: true };
  var media = window.matchMedia("(prefers-color-scheme: dark)");
  var stored = localStorage.getItem(storageKey);
  var preference = stored && valid[stored] ? stored : "system";
  root.dataset.theme = preference;
  root.style.colorScheme =
    preference === "system" ? (media.matches ? "dark" : "light") : preference;
})();`;
---

<!doctype html>
<html lang="zh-CN" class="no-js" data-theme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={authorMeta} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts: Space Grotesk (UI chrome) + Source Serif 4 (reading) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=Space+Grotesk:wght@500;600;700&display=swap" />

    <script is:inline set:html={themeInitScript} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <div class="shell">
          <a href="/" class="brand">MyBlog</a>
          <div class="site-header-search-slot" data-header-search-slot>
            <HeaderSearch />
          </div>
          <nav class="site-nav">
            <div class="site-nav-links">
              {navItems.map((item) => (
                <a href={item.href} aria-current={currentSection === item.section ? "page" : undefined}>
                  {item.label}
                </a>
              ))}
            </div>
            <div class="site-nav-tools">
              <button
                id="theme-toggle"
                type="button"
                class="theme-toggle"
                aria-label="切换主题（当前：跟随系统）"
                aria-live="polite"
                title="切换主题"
              >
                <span class="theme-toggle-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="4.1"></circle>
                    <path d="M12 2.8v2.3"></path>
                    <path d="M12 18.9v2.3"></path>
                    <path d="M4.8 4.8l1.6 1.6"></path>
                    <path d="M17.6 17.6l1.6 1.6"></path>
                    <path d="M2.8 12h2.3"></path>
                    <path d="M18.9 12h2.3"></path>
                    <path d="M4.8 19.2l1.6-1.6"></path>
                    <path d="M17.6 6.4l1.6-1.6"></path>
                  </svg>
                </span>
                <span class="theme-toggle-label">系统</span>
              </button>
            </div>
          </nav>
        </div>
      </div>
    </header>
    <main class:list={["shell", mainClass]}>
      <slot />
    </main>
    <SiteFooter />

    <!-- Back to Top -->
    <button
      id="back-to-top"
      type="button"
      class="back-to-top"
      aria-label="回到顶部"
      title="回到顶部"
    >
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script is:inline>
      (function () {
        document.documentElement.classList.remove('no-js');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var STAGGER_MS = 60;
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            var delay = parseInt(el.dataset.uxDelay || '0', 10);
            el.style.animationDelay = delay + 'ms';
            el.classList.add('ux-revealed');
            observer.unobserve(el);
          });
        }, {
          threshold: 0.08,
          rootMargin: '0px 0px -40px 0px'
        });
        document.querySelectorAll('[data-ux-reveal]').forEach(function (el) {
          observer.observe(el);
        });
        document.querySelectorAll('[data-ux-stagger]').forEach(function (parent) {
          var children = parent.querySelectorAll('[data-ux-reveal]');
          children.forEach(function (child, i) {
            child.dataset.uxDelay = String(i * STAGGER_MS);
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var toggle = document.getElementById("theme-toggle");
        if (!toggle) return;

        var storageKey = "theme-preference";
        var order = ["system", "light", "dark"];

        var icons = {
          system: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.1"></circle><path d="M12 2.8v2.3"></path><path d="M12 18.9v2.3"></path><path d="M4.8 4.8l1.6 1.6"></path><path d="M17.6 17.6l1.6 1.6"></path><path d="M2.8 12h2.3"></path><path d="M18.9 12h2.3"></path><path d="M4.8 19.2l1.6-1.6"></path><path d="M17.6 6.4l1.6-1.6"></path></svg>',
          light:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.4"></circle><path d="M12 2.3v2.8"></path><path d="M12 18.9v2.8"></path><path d="M5.2 5.2l2 2"></path><path d="M16.8 16.8l2 2"></path><path d="M2.3 12h2.8"></path><path d="M18.9 12h2.8"></path><path d="M5.2 18.8l2-2"></path><path d="M16.8 7.2l2-2"></path></svg>',
          dark:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 14.7A8.4 8.4 0 1 1 9.3 3.8a6.9 6.9 0 1 0 10.9 10.9Z"></path></svg>'
        };
        var labels = {
          system: "系统",
          light:  "亮色",
          dark:   "深色"
        };
        var ariaLabels = {
          system: "切换主题（当前：跟随系统）",
          light:  "切换主题（当前：亮色）",
          dark:   "切换主题（当前：深色）"
        };

        var iconEl  = toggle.querySelector(".theme-toggle-icon");
        var labelEl = toggle.querySelector(".theme-toggle-label");
        var media = window.matchMedia("(prefers-color-scheme: dark)");

        function getPreference() {
          var stored = localStorage.getItem(storageKey);
          return order.indexOf(stored || "") > -1 ? stored : "system";
        }

        function applyPreference(preference) {
          root.classList.add("theme-transitioning");
          root.dataset.theme = preference;
          root.style.colorScheme =
            preference === "system" ? (media.matches ? "dark" : "light") : preference;
          if (iconEl)  iconEl.innerHTML  = icons[preference];
          if (iconEl) {
            iconEl.style.animation = 'none';
            iconEl.offsetHeight;
            iconEl.style.animation = 'ux-icon-rotate 500ms cubic-bezier(0.34, 1.56, 0.64, 1)';
          }
          if (labelEl) labelEl.textContent = labels[preference];
          toggle.setAttribute("aria-label", ariaLabels[preference]);
          window.setTimeout(function () {
            root.classList.remove("theme-transitioning");
          }, 1750);
        }

        function cyclePreference() {
          var current = getPreference();
          var currentIndex = order.indexOf(current);
          var next = order[(currentIndex + 1) % order.length];
          localStorage.setItem(storageKey, next);
          applyPreference(next);
        }

        applyPreference(getPreference());
        toggle.addEventListener("click", cyclePreference);

        media.addEventListener("change", function () {
          if (getPreference() === "system") {
            applyPreference("system");
          }
        });

        // Back to Top
        (function () {
          var btn = document.getElementById("back-to-top");
          if (!btn) return;
          var THRESHOLD = 300;
          var visible = false;

          function updateVisibility() {
            var shouldShow = window.scrollY > THRESHOLD;
            if (shouldShow !== visible) {
              visible = shouldShow;
              btn.classList.toggle("is-visible", visible);
            }
          }

          window.addEventListener("scroll", updateVisibility, { passive: true });
          updateVisibility();

          btn.addEventListener("click", function () {
            var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            window.scrollTo({ top: 0, behavior: prefersReduced ? "auto" : "smooth" });
          });
        })();

        // Navbar hide-on-scroll-down / show-on-scroll-up
        (function () {
          var header = document.querySelector(".site-header");
          if (!header) return;
          var isArticleReading = Boolean(document.querySelector(".shell--article-reading"));
          function notifyHeaderFrameChange() {
            window.dispatchEvent(new CustomEvent("site-header-framechange"));
          }

          var lastY = window.scrollY;
          var ticking = false;
          var SCROLL_THRESHOLD = 20;   // px before border appears
          var HIDE_THRESHOLD   = 80;   // px scrolled down before hide triggers
          var SHOW_DELTA       = 12;   // px scrolled up before show triggers

          function update() {
            var y = window.scrollY;
            var delta = y - lastY;

            // Border fade-in after first scroll past threshold
            header.classList.toggle("is-scrolled", y > SCROLL_THRESHOLD);

            if (isArticleReading) {
              header.classList.remove("is-hidden");
              notifyHeaderFrameChange();
              lastY = y;
              ticking = false;
              return;
            }

            // Only hide/show after enough initial scroll
            if (y > HIDE_THRESHOLD) {
              if (delta > 6) {
                // Scrolling DOWN — hide header
                header.classList.add("is-hidden");
              } else if (delta < -SHOW_DELTA) {
                // Scrolling UP — show header
                header.classList.remove("is-hidden");
              }
            } else {
              // Near top — always show
              header.classList.remove("is-hidden");
            }

            lastY = y;
            notifyHeaderFrameChange();
            ticking = false;
          }

          window.addEventListener("scroll", function () {
            if (!ticking) {
              window.requestAnimationFrame(update);
              ticking = true;
            }
          }, { passive: true });

          // Init state
          header.classList.toggle("is-scrolled", window.scrollY > SCROLL_THRESHOLD);
          notifyHeaderFrameChange();
        })();
      })();
    </script>
  </body>
</html>
